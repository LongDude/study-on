
<form class="d-inline-block" method="post" action="{{ path('app_course_delete', {'id': course.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
    <button type="submit" class="btn btn-danger d-inline-block text-nowrap">Удалить курс</button>
</form>
