{% extends 'base.html.twig' %}

{% block title %}Редактирование курса / StudyOn{% endblock %}

{% block body %}
    <nav>
        <span>StudyOn</span>
        /
        <a href="{{ path('app_course_index') }}">Список курсов</a>
        /
        <a href="{{ path('app_course_show', {'id': course.id }) }}">{{  course.name }}</a>
    </nav>

    <h1>{{ course.name }}: Редактировать курс</h1>

    {{ form_start(form) }}
        {{ form_row(form.name) }}
        {{ form_row(form.description) }}
        {% do form.symbolic_name.setRendered() %}
    {{ form_end(form) }}

    {{ include('course/_delete_form.html.twig') }}
{% endblock %}
