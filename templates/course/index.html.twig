{% extends 'base.html.twig' %}

{% block title %}Список курсов / StudyOn{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item active">Список курсов</li>
{% endblock %}

{% block body %}
    <div class="row mb-3">
        {% for course in courses %}
            <div class="col-sm-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">{{ course.name }}
                            {% if course.is_active %}
                                {% if course.type == 'rent' %}
                                    <span
                                        class="badge bg-success text-bg-dark">Арендован до: {{ course.valid_until }}</span>
                                {% else %}
                                    <span class="badge bg-success text-bg-dark">Куплено!</span>
                                {% endif %}
                            {% else %}
                                {% if course.type == 'rent' %}
                                    <span class="badge bg-primary text-bg-dark">Аренда: {{ course.price }}</span>
                                {% elseif course.type == 'free' %}
                                    <span class="badge bg-warning text-dark">Бесплатно!</span>
                                {% elseif course.type == "paid" %}
                                    <span class="badge bg-primary text-bg-dark">Покупка: {{ course.price }}</span>
                                {% endif %}
                            {% endif %}
                        </h5>
                        <p class="card-text">{{ course.description }}</p>
                    </div>
                    <div class="card-footer">
                        <a href="{{ path('app_course_show', {'id': course.id}) }}" class="btn btn-primary">Перейти к
                            курсу</a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="alert alert-info" role="alert">
                <div>Курсы не найдены.</div>
            </div>
        {% endfor %}
    </div>

    <hr class="hr"/>
    {% if is_granted("ROLE_SUPER_ADMIN") %}
        {{ include('course/_add_button.html.twig') }}
    {% endif %}
{% endblock %}
