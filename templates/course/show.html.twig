{% extends 'base.html.twig' %}

{% block title %}{{ course.name }} / StudyOn{% endblock %}

{% block body %}
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_course_index') }}">StudyOn</a></li>
            <li class="breadcrumb-item active">{{ course.name }}</li>
        </ol>
    </nav>

    <h1>{{ course.name }}</h1>
    <p> {{ course.description }}</p>

    <h2>Доступные уроки:</h2>
    <ul class="unmarked-list">
        {% for lesson in course.lessons %}
            <li>
                <div>
                    <h4>
                        {{ lesson.index }}. <a href="{{ path('app_lesson_show', {'id': lesson.id}) }}">{{ lesson.name }}</a>
                    </h4>
                    <p>
                        {{ lesson.content }}
                    </p>
                </div>
            </li>
        {% else %}
            <li>Уроки не найдены</li>
        {% endfor %}
    </ul>

    <div class="btn-group" role="group">
        <button type="button" class="btn btn-success" onclick="window.location.href='{{ path('app_lesson_new') }}?course_id={{ course.id }}'">Добавить урок</button>
        <button type="button" class="btn btn-primary" onclick="window.location.href='{{ path('app_course_edit', {'id': course.id}) }}'">Редактировать курс</button>

        {{ include('course/_delete_form.html.twig') }}
    </div>
{% endblock %}
