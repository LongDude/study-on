{% extends 'base.html.twig' %}

{% block title %}Редактирование урока / StudyOn {% endblock %}

{% block breadcrumbs %}
<li class="breadcrumb-item"><a href="{{ path('app_course_show', {'id': lesson.course.id }) }}">{{ lesson.course.name }}</a></li>
<li class="breadcrumb-item active"><a href="{{  path('app_lesson_show', {'id': lesson.id}) }}">{{ lesson.name }}</a></li>
{% endblock %}
{% block body %}
    <h1>Редактировать урок</h1>
    {{ include('lesson/_form.html.twig', {'button_label': 'Обновить'}) }}

    <hr class="hr"/>
    <div class="container-fluid p-0">
        {{ include('lesson/_delete_form.html.twig') }}
    </div>
{% endblock %}
