{% extends 'base.html.twig' %}

{% block title %}Список уроков / StudyOn {% endblock %}

{% block body %}
    <nav>
        <span>
            StudyOn
        </span>
        /
        <span>
            Список уроков
        </span>
    </nav>

    <h1>Список уроков</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Курс</th>
                <th>Урок</th>
                <th>Описание</th>
            </tr>
        </thead>
        <tbody>
        {% for lesson in lessons %}
            <tr>
                <td><a href="{{ path('app_course_show', {'id': lesson.course.id}) }}">{{ lesson.course.name }}</a></td>
                <td><a href="{{ path('app_lesson_show', {'id': lesson.id}) }}">{{ lesson.index }}.{{ lesson.name }}</a></td>
                <td>{{ lesson.content }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <button class="btn" onclick="window.location.href='{{ path('app_lesson_new') }}'">Добавить урок</button>
{% endblock %}
