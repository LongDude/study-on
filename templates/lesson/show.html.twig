{% extends 'base.html.twig' %}

{% block title %}{{ lesson.name }}/{{ lesson.course.name }}/StudyOn{% endblock %}

{% block body %}
    <nav>
        <span>StudyOn</span>
        /
        <a href="{{ path('app_course_index') }}">Список курсов</a>
        /
        <a href="{{ path('app_course_show', {'id': lesson.course.id }) }}">{{ lesson.course.name }}</a>
        /
        <span>{{ lesson.name }}</span>
    </nav>

    <h1>{{ lesson.index }}. {{ lesson.name }}</h1>
    <p>{{ lesson.content }}</p>

    {{ include('lesson/_edit_button.html.twig') }}

    {{ include('lesson/_delete_form.html.twig') }}
{% endblock %}
