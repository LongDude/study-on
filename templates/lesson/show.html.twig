{% extends 'base.html.twig' %}

{% block title %}{{ lesson.name }}/{{ lesson.course.name }}/StudyOn{% endblock %}

{% block breadcrumbs %}
    <li class="breadcrumb-item"><a href="{{ path('app_course_show', {'id': lesson.course.id }) }}">{{ lesson.course.name }}</a></li>
    <li class="breadcrumb-item active">{{ lesson.name }}</li>
{% endblock %}

{% block body %}
    <h1>{{ lesson.index }}. {{ lesson.name }}</h1>
    <p>{{ lesson.content }}</p>

    {% if is_granted("ROLE_SUPER_ADMIN") %}
        <div class="container-fluid p-0">
            {{ include('lesson/_edit_button.html.twig') }}
            {{ include('lesson/_delete_form.html.twig') }}
        </div>
    {% endif %}

{% endblock %}
